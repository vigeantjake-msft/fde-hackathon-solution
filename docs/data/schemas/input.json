{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Ticket",
    "description": "An IT support ticket submitted to Contoso Financial Services.",
    "type": "object",
    "required": [
        "ticket_id",
        "subject",
        "description",
        "reporter",
        "created_at",
        "channel"
    ],
    "properties": {
        "ticket_id": {
            "type": "string",
            "description": "Unique ticket identifier (e.g., INC-4829).",
            "pattern": "^INC-[0-9]+$"
        },
        "subject": {
            "type": "string",
            "description": "Short summary or subject line of the ticket. May be missing, vague, or misleading."
        },
        "description": {
            "type": "string",
            "description": "Full ticket body. Quality varies: may be detailed, terse, garbled, or empty."
        },
        "reporter": {
            "type": "object",
            "required": [
                "name",
                "email",
                "department"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Reporter's full name."
                },
                "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Reporter's email address at contoso.com."
                },
                "department": {
                    "type": "string",
                    "description": "Business department (e.g., Wealth Management, Trading, Compliance, HR, IT, Finance)."
                }
            }
        },
        "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of when the ticket was created."
        },
        "channel": {
            "type": "string",
            "enum": [
                "email",
                "chat",
                "portal",
                "phone"
            ],
            "description": "How the ticket was submitted."
        },
        "attachments": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Filenames of attachments mentioned in the ticket. Actual files are not provided — only names."
        }
    }
}
