{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "DocumentInput",
    "description": "A document image to extract structured data from. Each document comes with a json_schema describing the expected output fields.",
    "type": "object",
    "required": [
        "document_id",
        "content",
        "content_format"
    ],
    "properties": {
        "document_id": {
            "type": "string",
            "description": "Unique document identifier (e.g., DOC-OCR-0366)."
        },
        "content": {
            "type": "string",
            "description": "Base64-encoded document image."
        },
        "content_format": {
            "type": "string",
            "enum": ["image_base64"],
            "description": "Format of the content field."
        },
        "json_schema": {
            "type": ["string", "null"],
            "description": "JSON schema (as a string) describing the expected output structure. Each document has a different schema."
        }
    }
}
