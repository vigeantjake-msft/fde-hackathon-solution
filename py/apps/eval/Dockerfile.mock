FROM python:3.12-slim
COPY --from=ghcr.io/astral-sh/uv:0.9.5 /uv /bin/
WORKDIR /code
COPY pyproject.toml uv.lock ./
COPY apps/eval/ ./apps/eval/
COPY common/ ./common/
RUN uv sync --package eval --frozen --no-cache
ENV PYTHONPATH=/code/apps/eval:/code/common/libs/models/src:/code/common/libs/fdebenchkit/src
ENV PATH=/code/.venv/bin:$PATH
WORKDIR /code/apps/eval
EXPOSE 9090
CMD ["python", "mock_tool_service.py", "--port", "9090"]
