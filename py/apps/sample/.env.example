# ── Azure AI Foundry ──────────────────────────────────────────────────────────
# Required: endpoint of your Azure AI Foundry resource
AZURE_OPENAI_ENDPOINT=https://<your-foundry-resource>.cognitiveservices.azure.com/

# Optional: override the API version (default: 2025-01-01-preview)
# AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Per-task model deployments ────────────────────────────────────────────────
# Deployment names as shown in your AI Foundry project.
# Cost-tier scoring: nano=1.0, mini=0.9, standard=0.75
TRIAGE_MODEL=gpt-5.4          # complex classification — use a capable model
EXTRACT_MODEL=gpt-4-1-mini    # vision extraction — mini is sufficient
ORCHESTRATE_MODEL=gpt-4-1-mini  # tool calling — mini handles this well

# Optional: override the X-Model-Name header returned on every response.
# Defaults to TRIAGE_MODEL.  FDEBench reads this header for cost-tier scoring.
# MODEL_HEADER=gpt-4-1-mini

# ── Operational knobs ─────────────────────────────────────────────────────────
# AI_MAX_RETRIES=3
# LLM_CALL_TIMEOUT_S=120.0
# ORCHESTRATE_MAX_TURNS=40
# TOOL_CALL_TIMEOUT_S=30.0

# ── Platform injection (set automatically by Azure Container Apps) ─────────────
# When deployed, the platform injects AZURE_OPENAI_BACKENDS (JSON array of
# backend objects) which overrides AZURE_OPENAI_ENDPOINT.
# AZURE_OPENAI_BACKENDS=[{"name":"primary","endpoint":"https://...","deployment":"gpt-4-1-mini"}]
