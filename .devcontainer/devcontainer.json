{
    "features": {
        "ghcr.io/devcontainers-extra/features/pulumi:1": {
            "bashCompletion": true,
            "version": "latest"
        },
        "ghcr.io/devcontainers-extra/features/uv:1": {
            "version": "latest"
        }
    },
    "postCreateCommand": {
        "auto-push-remote": "git config push.autoSetupRemote true",
        "claude-cli-install": "curl -fsSL https://claude.ai/install.sh | bash",
        "copilot-cli-install": "curl -fsSL https://gh.io/copilot-install | bash",
        "pre-commit-install": "uvx pre-commit install && uvx pre-commit run --all-files",
        "py-install": "cd py && uv sync",
        "ts-install": "cd ts && pnpm install"
    }
}
